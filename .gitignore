vendor/
# Magento 2 .gitignore

# === System Files ===
.DS_Store
Thumbs.db
*.bak
*.tmp
*.swp

# === Composer ===
/vendor/
/composer.lock

# === Magento Generated Content ===
/generated/
/pub/static/*
!/pub/static/.htaccess
/var/*
!/var/.htaccess
/app/etc/env.php
/app/etc/config.php

# === Cache and Logs ===
/var/cache/
/var/composer_home/
/var/page_cache/
/var/view_preprocessed/
/var/log/
/var/report/
/var/session/
/var/tmp/

# === Static Deploy (when not using --symlink) ===
/pub/static/frontend/
/pub/static/adminhtml/

# === IDEs and Tools ===
.idea/
.vscode/
.phpstorm.meta.php

# === NPM/Yarn ===
/node_modules/
/package-lock.json
/yarn.lock

# === PHPUnit ===
/phpunit.xml

# === Docker / Vagrant ===
/docker-compose.override.yml
/.docker/
/.vagrant/
Homestead.yaml
Homestead.json

# === Others ===
/auth.json
/nginx.conf
*.iml
*.log
*.sublime*

# === Optional: media folder (only if not versioning product images) ===
/pub/media/*
!/pub/media/.htaccess
